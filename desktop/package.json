{
  "name": "labora-desktop",
  "version": "0.1.0",
  "description": "Labora Desktop App",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "preview": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.labora.app",
    "productName": "Labora",
    "files": ["dist-electron/**/*", "dist-frontend/**/*"],
    "extraResources": [
      { "from": "resources/backend", "to": "backend" }
    ],
    "mac": { "target": ["dmg"] },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage"] }
  }
}
