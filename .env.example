# Labora 配置文件示例
# 复制此文件为 .env 并填入你的 API 密钥

# OpenAI API 密钥（用于论文分析和信息提取）
OPENAI_API_KEY=your_openai_api_key_here

# 可选：指定 OpenAI API 基础 URL（如使用代理或自定义端点）
# OPENAI_API_BASE=https://api.openai.com/v1

# 可选：指定默认模型
# OPENAI_MODEL=gpt-4o-mini

# 可选：指定项目目录（默认为启动 Labora 时的当前工作目录）
# 默认数据会写入 LABORA_PROJECT_DIR/.labora
# LABORA_PROJECT_DIR=/path/to/your/project

# 可选：指定数据存储目录（默认为 项目目录/.labora）
# LABORA_DATA_DIR=/path/to/your/data/directory

# 可选：指定数据库文件路径（默认为 data_dir/labora.db）
# DB_PATH=/path/to/your/labora.db

# 可选：PDF 预览策略
# auto: 有 latexmk 时本地编译，否则回退到 arXiv PDF
# compile: 优先本地编译，失败后回退到 arXiv PDF
# remote: 始终使用 arXiv PDF，不依赖本机 TeX 工具链
# disabled: 关闭 PDF 预览，仅显示解析后的 LaTeX 正文
# 默认策略：auto
# PDF_PREVIEW_MODE=auto
